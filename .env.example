# =============================================================================
# INSTRUÇÕES PARA CONFIGURAÇÃO DE E-MAIL
# =============================================================================
# Para configurar o envio de e-mails, siga estas etapas:
#
# 1. CONFIGURAÇÃO GMAIL (Recomendado):
#    - Ative a verificação em 2 etapas na sua conta Google
#    - Gere uma senha de app: https://myaccount.google.com/apppasswords
#    - Use essa senha no MAIL_PASSWORD
#
# 2. CONFIGURAÇÕES NECESSÁRIAS:
#    MAIL_MAILER=smtp
#    MAIL_HOST=smtp.gmail.com
#    MAIL_PORT=587
#    MAIL_USERNAME=seu-email@gmail.com
#    MAIL_PASSWORD=sua-senha-app
#    MAIL_ENCRYPTION=tls
#
# 3. CONFIGURAÇÕES DE FILAS (Jobs):
#    QUEUE_CONNECTION=database
#    QUEUE_FAILED_DRIVER=database-uuids
#
# 4. EXECUTAR MIGRAÇÕES:
#    php artisan queue:table
#    php artisan migrate
#
# 5. INICIAR WORKER DE FILAS:
#    php artisan queue:work
#
# 6. TESTAR CONFIGURAÇÃO:
#    php artisan test:quiz-email --type=direct

